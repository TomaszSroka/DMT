{
  "name": "dmt",
  "version": "1.0.0",
  "private": true,
  "description": "Web app for browsing and editing Snowflake dictionaries",
  "main": "backend/api/app.js",
  "scripts": {
    "start": "node backend/api/app.js",
    "dev": "node --watch backend/api/app.js",
    "local:start": "powershell -ExecutionPolicy Bypass -File scripts/local-run-app.ps1",
    "local:restart": "powershell -ExecutionPolicy Bypass -File scripts/local-run-app.ps1 -Restart",
    "local:db": "powershell -ExecutionPolicy Bypass -File scripts/local-recreate-db.ps1 -apply",
    "local:db:plan": "powershell -ExecutionPolicy Bypass -File scripts/local-recreate-db.ps1 -list",
    "local:test": "powershell -ExecutionPolicy Bypass -File scripts/local-run-tests.ps1",
    "test:api-contract": "node --test backend/api/api.contract.test.js",
    "test:unit": "node --test backend/services/table.validation.test.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "snowflake-sdk": "^1.13.1"
  }
}
